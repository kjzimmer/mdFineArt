{
  "name": "melody-site-server",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "nodemon --watch src --exec tsx src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "prisma migrate deploy && node dist/index.js",
    "seed": "tsx prisma/seed.ts",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.0.0",
    "express-rate-limit": "^7.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "prisma": "^6.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.13.2",
    "@types/sharp": "^0.32.0",
    "eslint": "^8.57.0",
    "nodemon": "^3.0.4",
    "tsx": "^4.12.0",
    "typescript": "^5.6.2"
  }
}
