generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  AVAILABLE
  SOLD
  RESERVED
  NFS
}

enum PrintType {
  PAPER
  CANVAS
}

model Painting {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  status          Status        @default(AVAILABLE)
  subject         String
  tags            String[]      @default([])
  year            Int?
  dimensions      String?
  medium          String?
  price           Float?
  originalWidth   Int?
  originalHeight  Int?
  imageUrl        String
  fullResUrl      String?
  thumbUrl        String?
  printsAvailable Boolean       @default(false)
  featured        Boolean       @default(false)
  description     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  printProducts   PrintProduct[]
  spotlights      Spotlight[]
  orderItems      OrderItem[]
}

model PrintProduct {
  id                String    @id @default(cuid())
  paintingId        String
  painting          Painting  @relation(fields: [paintingId], references: [id])
  type              PrintType
  size              String
  price             Float
  squareItemId      String?
  squareVariationId String?
  createdAt         DateTime  @default(now())
}

model Spotlight {
  id         String   @id @default(cuid())
  paintingId String   @unique
  painting   Painting @relation(fields: [paintingId], references: [id])
  position   Int      @unique
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

enum OrderStatus {
  DRAFT
  INVOICE_SENT
  PAID
  CANCELLED
}

enum CommissionStatus {
  NEW
  REVIEWING
  QUOTED
  ACCEPTED
  IN_PROGRESS
  COMPLETE
  DECLINED
}

model Order {
  id              String      @id @default(cuid())
  personId        String?
  person          Person?     @relation(fields: [personId], references: [id], onDelete: SetNull)
  status          OrderStatus @default(INVOICE_SENT)
  amount          Float
  notes           String?
  squareInvoiceId String?
  squareOrderId   String?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id             String    @id @default(cuid())
  orderId        String
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paintingId     String?
  painting       Painting? @relation(fields: [paintingId], references: [id], onDelete: SetNull)
  printProductId String?
  label          String
  quantity       Int       @default(1)
  unitPrice      Float
}

model Person {
  id           String                @id @default(cuid())
  name         String
  email        String                @unique
  phone        String?
  notes        String?
  tags         String[]              @default([])
  isAdmin      Boolean               @default(false) @map("is_admin")
  passwordHash String?               @map("password_hash")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  contacts     ContactMessage[]
  commissions  CommissionRequest[]
  newsletter   NewsletterSubscriber?
  orders       Order[]
  sessions     RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  personId  String    @map("person_id")
  person    Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("refresh_token")
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  personId     String   @unique
  person       Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  active       Boolean  @default(true)
  source       String?
  sourceSite   String?  @map("source_site")
  subscribedAt DateTime @default(now())
}

model ContactMessage {
  id         String   @id @default(cuid())
  personId   String?
  person     Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  name       String
  email      String
  phone      String?
  subject    String
  message    String
  read       Boolean  @default(false)
  sourceSite String?  @map("source_site")
  createdAt  DateTime @default(now())
}

model CommissionRequest {
  id          String           @id @default(cuid())
  personId    String?
  person      Person?          @relation(fields: [personId], references: [id], onDelete: SetNull)
  name        String
  email       String
  phone       String?
  subject     String
  description String
  status      CommissionStatus @default(NEW)
  adminNotes  String?
  createdAt   DateTime         @default(now())
}

model SiteConfig {
  id                 String   @id @default("singleton")
  siteTitle          String?  @map("site_title")
  taglinePrimary     String?  @map("tagline_primary")
  taglineSecondary   String?  @map("tagline_secondary")
  taglineFooter      String?  @map("tagline_footer")
  heroImageUrl       String?  @map("hero_image_url")
  heroThumbUrl       String?  @map("hero_thumb_url")
  heroFullResUrl     String?  @map("hero_full_res_url")
  commissionsEnabled Boolean  @default(true) @map("commissions_enabled")
  commissionTitle    String?  @map("commission_title")
  commissionBody     String[] @default([]) @map("commission_body")
  featuredEnabled    Boolean  @default(true) @map("featured_enabled")
  featuredCount      Int      @default(6) @map("featured_count")
  newsletterEnabled  Boolean  @default(true) @map("newsletter_enabled")
  newsletterTitle    String?  @map("newsletter_title")
  newsletterTagline  String?  @map("newsletter_tagline")
  eventsEnabled      Boolean  @default(true) @map("events_enabled")
  blogEnabled        Boolean  @default(false) @map("blog_enabled")
  musicEnabled       Boolean  @default(false) @map("music_enabled")
  showPrice          Boolean  @default(true) @map("show_price")

  // Site Info
  contactEmail       String?  @map("contact_email")
  contactPhone       String?  @map("contact_phone")
  studioLocation     String?  @map("studio_location")
  timezone           String?
  metaDescription    String?  @map("meta_description")
  ogImageUrl         String?  @map("og_image_url")

  // Contact
  contactHeading     String?  @map("contact_heading")
  contactBody        String[] @default([]) @map("contact_body")
  studioImageUrl     String?  @map("studio_image_url")
  contactImageCaption String? @map("contact_image_caption")

  // About Page
  aboutName          String?  @map("about_name")
  aboutBioSubtitle   String?  @map("about_bio_subtitle")
  aboutBio           String[] @default([]) @map("about_bio")
  aboutStatSubtitle  String?  @map("about_stat_subtitle")
  aboutStatement     String[] @default([]) @map("about_statement")
  profileImageUrl    String?  @map("profile_image_url")
  profileThumbUrl    String?  @map("profile_thumb_url")
  profileFullResUrl  String?  @map("profile_full_res_url")
  aboutStatImage1Url String?  @map("about_stat_image1_url")
  aboutStatImage2Url String?  @map("about_stat_image2_url")
  aboutShows         Json     @default("[]") @map("about_shows")
  aboutAwards        Json     @default("[]") @map("about_awards")
  aboutMedia         Json     @default("[]") @map("about_media")
  aboutGalleries     Json     @default("[]") @map("about_galleries")
  aboutMemberships   Json     @default("[]") @map("about_memberships")

  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}

model SocialLink {
  id        String   @id @default(cuid())
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([position])
  @@map("social_link")
}

model SlideshowSlide {
  id         String   @id @default(cuid())
  context    String
  imageUrl   String   @map("image_url")
  thumbUrl   String?  @map("thumb_url")
  fullResUrl String?  @map("full_res_url")
  caption    String?
  position   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([context, position])
  @@map("slideshow_slide")
}

model DailyAnalytics {
  id             String   @id @default(cuid())
  date           DateTime @unique @db.Date
  uniqueVisitors Int      @map("unique_visitors")
  pageViews      Int      @map("page_views")
  requests       Int
  bandwidth      Int
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("daily_analytics")
}
